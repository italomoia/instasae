# instasae — Environment Variables
# Copy to .env and fill in real values. NEVER commit .env to git.

# ── Production (Docker Swarm) ────────────────────────────
# These are used by docker-compose.prod.yml on the VPS.
# INSTASAE_DB_PASSWORD=<strong password for instasae postgres user>
# DATABASE_URL is constructed in docker-compose.prod.yml from INSTASAE_DB_PASSWORD
# REDIS_URL=redis://redis:6379/3 (index 3; 0=default, 2=n8n, 8=evolution)
INSTASAE_DOMAIN=instasae.imsdigitais.com
INSTASAE_DB_PASSWORD=STRONG_PASSWORD_HERE

# ── Server ──────────────────────────────────────────────
PORT=8080
LOG_LEVEL=debug   # debug | info | warn | error

# ── PostgreSQL ──────────────────────────────────────────
# Dev: postgres://instasae:instasae_dev@localhost:5435/instasae?sslmode=disable
# Prod: constructed from INSTASAE_DB_PASSWORD in docker-compose.prod.yml
DATABASE_URL=postgres://instasae:instasae_dev@localhost:5435/instasae?sslmode=disable

# ── Redis ───────────────────────────────────────────────
# Dev: redis://localhost:6382/0
# Prod: redis://redis:6379/3 (index 3 to avoid collisions)
REDIS_URL=redis://localhost:6382/0

# ── Meta (Instagram) ───────────────────────────────────
# Facebook App Secret from Meta Developer Dashboard → App Settings → Basic
META_APP_SECRET=YOUR_META_APP_SECRET
# API version pinned
META_GRAPH_API_VERSION=v25.0
# Set to true only after Meta approves the human_agent permission
ENABLE_HUMAN_AGENT_TAG=false

# ── OAuth (optional — leave empty to disable OAuth flow) ──
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
OAUTH_REDIRECT_URI=https://instasae.imsdigitais.com/oauth/callback

# ── Backblaze B2 (S3-compatible) ───────────────────────
B2_ENDPOINT=https://s3.us-west-004.backblazeb2.com
B2_REGION=us-west-004
B2_BUCKET=YOUR_BUCKET_NAME
B2_KEY_ID=YOUR_B2_KEY_ID
B2_APPLICATION_KEY=YOUR_B2_APP_KEY
B2_PUBLIC_URL=https://f004.backblazeb2.com/file/YOUR_BUCKET_NAME
B2_PREFIX=instasae

# ── Encryption ──────────────────────────────────────────
# 32 bytes as 64 hex characters. Generate with: openssl rand -hex 32
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ── Admin API ───────────────────────────────────────────
# Strong random string for X-API-Key header. Generate with: openssl rand -hex 24
ADMIN_API_KEY=YOUR_ADMIN_API_KEY

# ── Webhook ─────────────────────────────────────────────
# Global fallback verify token for Meta webhook handshake
WEBHOOK_VERIFY_TOKEN=YOUR_VERIFY_TOKEN
